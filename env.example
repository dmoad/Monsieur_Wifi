# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# REQUIRED: Application name displayed throughout the system
APP_NAME=Monsieur-WiFi

# REQUIRED: Application environment: local, staging, production
APP_ENV=local

# REQUIRED: Application encryption key (generate with: php artisan key:generate)
# This key is used for encryption and should be unique for each installation
APP_KEY=

# Enable/disable debug mode (set to false in production)
APP_DEBUG=true

# REQUIRED: Base URL of the application (used for generating absolute URLs)
APP_URL=https://portal.monsieur-wifi.com

# URL to redirect users after successful captive portal authentication
SOLUTION_URL=https://citypassenger.com

# =============================================================================
# LOCALIZATION SETTINGS
# =============================================================================

# Default application locale (language)
APP_LOCALE=en

# Fallback locale when translation is missing
APP_FALLBACK_LOCALE=en

# Locale for Faker library (used in testing/seeding)
APP_FAKER_LOCALE=en_US

# =============================================================================
# MAINTENANCE MODE
# =============================================================================

# Driver for storing maintenance mode state: file or database
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Number of workers for PHP built-in server (development only)
PHP_CLI_SERVER_WORKERS=4

# Number of rounds for bcrypt password hashing (higher = more secure but slower)
BCRYPT_ROUNDS=12

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log channel: stack, single, daily, slack, syslog, errorlog, null
LOG_CHANNEL=stack

# Log stack configuration
LOG_STACK=single

# Channel for deprecation warnings
LOG_DEPRECATIONS_CHANNEL=null

# Minimum log level: emergency, alert, critical, error, warning, notice, info, debug
LOG_LEVEL=debug

# =============================================================================
# DATABASE CONFIGURATION - MAIN DATABASE
# =============================================================================

# REQUIRED: Database connection type: mysql, pgsql, sqlite, sqlsrv
DB_CONNECTION=mysql

# REQUIRED: Database host address
DB_HOST=127.0.0.1

# REQUIRED: Database port
DB_PORT=3306

# REQUIRED: Database name
DB_DATABASE=mrwifi

# REQUIRED: Database username
DB_USERNAME=mrwifi_user

# REQUIRED: Database password
DB_PASSWORD=your_secure_password_here

# =============================================================================
# DATABASE CONFIGURATION - RADIUS DATABASE
# =============================================================================
# Separate database for RADIUS authentication (used for WiFi authentication)

# REQUIRED: RADIUS database connection type
DB_CONNECTION_RADIUS=mysql

# REQUIRED: RADIUS database host address
DB_HOST_RADIUS=127.0.0.1

# REQUIRED: RADIUS database port
DB_PORT_RADIUS=3306

# REQUIRED: RADIUS database name
DB_DATABASE_RADIUS=mrwifi_radius

# REQUIRED: RADIUS database username
DB_USERNAME_RADIUS=mrwifi_user

# REQUIRED: RADIUS database password
DB_PASSWORD_RADIUS=your_secure_password_here

# =============================================================================
# CAPTIVE PORTAL / UAM (Universal Access Method) SETTINGS
# =============================================================================

# REQUIRED: Secret code used for device verification and authentication
VERIFICATION_CODE=your_verification_code_here

# REQUIRED: URL where guests can log in to access the WiFi network
GUEST_LOGIN_URL=https://portal.monsieur-wifi.com/guest-login

# IP addresses that should be whitelisted (bypass authentication)
# Comma-separated list of IP addresses
GUEST_WHITELIST_SERVERS=127.0.0.1,example.com

# Domain names that should be whitelisted (bypass authentication)
# Comma-separated list of domains (use leading dot for subdomains: .example.com)
GUEST_WHITELIST_DOMAINS=.example.com,.test.com

# Twitter/X domain whitelist (for social login functionality)
# Domains that should be accessible during Twitter authentication
TWITTER_WHITELIST_DOMAINS=.twitter.com,.x.com,.twimg.com,.google.com,.googleapis.com,.gstatic.com

# Twitter/X server whitelist (IP addresses)
TWITTER_WHITELIST_SERVERS=twitter.com,x.com,twimg.com,google.com,googleapis.com,gstatic.com

# Facebook domain whitelist (for social login functionality)
# Domains that should be accessible during Facebook authentication
FACEBOOK_WHITELIST_DOMAINS=.facebook.com,.fbcdn.net,.graph.facebook.com

# Facebook server whitelist (IP addresses)
FACEBOOK_WHITELIST_SERVERS=facebook.com,fbcdn.net,graph.facebook.com

# Google domain whitelist (for social login functionality)
GOOGLE_WHITELIST_DOMAINS=.google.com,.googleapis.com,.gstatic.com

# Google server whitelist (IP addresses)
GOOGLE_WHITELIST_SERVERS=google.com,googleapis.com,gstatic.com

# =============================================================================
# SMS GATEWAY CONFIGURATION
# =============================================================================
# Configuration for BulkSMS service used to send OTP codes

# BulkSMS API username/account ID
BULKSMS_USERNAME=your_bulksms_username_here

# BulkSMS API password
BULKSMS_PASSWORD=your_bulksms_password_here

# Enable or disable SMS sending (set to false to disable OTP via SMS)
ENABLE_SMS_SENDING=true

# =============================================================================
# BRANDING & UI CONFIGURATION
# =============================================================================

# Brand name used in SMS messages and UI
APP_BRAND_NAME=monsieur-wifi

# Path to brand logo image (relative to public directory)
APP_BRAND_LOGO=/assets/images/Mr-Wifi.PNG

# Welcome message template ({{APP_NAME}} will be replaced with APP_NAME)
APP_BRAND_WELCOME_MESSAGE="Welcome to {{APP_NAME}}"

# URL path to terms of service page
APP_BRAND_TERMS_OF_SERVICE_URL=/terms-of-service

# URL path to privacy policy page
APP_BRAND_PRIVACY_POLICY_URL=/privacy-policy

# =============================================================================
# GOOGLE SERVICES
# =============================================================================

# Google Maps API key (for location services and maps)
GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================

# Session driver: file, cookie, database, apc, memcached, redis, array
SESSION_DRIVER=database

# Session lifetime in minutes
SESSION_LIFETIME=120

# Encrypt session data
SESSION_ENCRYPT=false

# Session cookie path
SESSION_PATH=/

# Session cookie domain (null = current domain)
SESSION_DOMAIN=null

# =============================================================================
# BROADCASTING & QUEUE CONFIGURATION
# =============================================================================

# Broadcasting connection: pusher, redis, log, null
BROADCAST_CONNECTION=log

# Default filesystem disk: local, public, s3
FILESYSTEM_DISK=local

# Queue connection: sync, database, beanstalkd, sqs, redis
QUEUE_CONNECTION=database

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Cache store: apc, array, database, file, memcached, redis, dynamodb, octane, null
CACHE_STORE=database
# CACHE_PREFIX=

# =============================================================================
# MEMCACHED CONFIGURATION
# =============================================================================

# Memcached server host
MEMCACHED_HOST=127.0.0.1

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis client: phpredis, predis
REDIS_CLIENT=phpredis

# Redis server host
REDIS_HOST=127.0.0.1

# Redis password (null if no password)
REDIS_PASSWORD=null

# Redis server port
REDIS_PORT=6379

# =============================================================================
# MAIL CONFIGURATION
# =============================================================================

# Mail driver: smtp, sendmail, mailgun, ses, postmark, log, array
MAIL_MAILER=log

# Mail encryption: tls, ssl, null
MAIL_SCHEME=null

# SMTP server host
MAIL_HOST=127.0.0.1

# SMTP server port
MAIL_PORT=2525

# SMTP username
MAIL_USERNAME=null

# SMTP password
MAIL_PASSWORD=null

# Default "from" email address
MAIL_FROM_ADDRESS="hello@portal.monsieur-wifi.com"

# Default "from" name (uses APP_NAME if not set)
MAIL_FROM_NAME="${APP_NAME}"

# Commercial team notification email (onboarding steps)
COMMERCIAL_NOTIFICATION_EMAIL=marketing@citypassenger.com

# Google Sheets Onboarding Tracking
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_CREDENTIALS_PATH=

# Subscription pricing config
STRIPE_TRIAL_DAYS=7
DEPOSIT_AMOUNT_CENTS=5000
SHIPPING_FEE_CENTS=1500

# =============================================================================
# AWS S3 CONFIGURATION (Optional)
# =============================================================================

# AWS access key ID (for S3 file storage)
AWS_ACCESS_KEY_ID=

# AWS secret access key
AWS_SECRET_ACCESS_KEY=

# AWS default region
AWS_DEFAULT_REGION=us-east-1

# AWS S3 bucket name
AWS_BUCKET=

# Use path-style endpoint (for S3-compatible services)
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# VITE / FRONTEND BUILD CONFIGURATION
# =============================================================================

# Application name for Vite build (uses APP_NAME if not set)
VITE_APP_NAME="${APP_NAME}"

# Stripe Configuration
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_PRICE_PREMIUM_YEARLY=
# =============================================================================
# JWT (JSON Web Token) CONFIGURATION
# =============================================================================

# REQUIRED: JWT secret key for token signing (generate a secure random string)
# This should be a long, random string for security
JWT_SECRET=your_jwt_secret_key_here
