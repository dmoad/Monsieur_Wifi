APP_NAME=monsieur-wifi
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_URL=https://portal.monsieur-wifi.com
SOLUTION_URL=https://citypassenger.com

APP_BRAND_NAME=monsieur-wifi
APP_BRAND_LOGO=/app-assets/mrwifi-assets/Mr-Wifi.PNG
APP_BRAND_WELCOME_MESSAGE="Welcome to {{APP_NAME}}"
APP_BRAND_TERMS_OF_SERVICE_URL=/terms-of-service
APP_BRAND_PRIVACY_POLICY_URL=/privacy-policy

GOOGLE_MAPS_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

DB_CONNECTION_RADIUS=mysql
DB_HOST_RADIUS=127.0.0.1
DB_PORT_RADIUS=3306
DB_DATABASE_RADIUS=
DB_USERNAME_RADIUS=
DB_PASSWORD_RADIUS=

VERIFICATION_CODE=
GUEST_LOGIN_URL=https://portal.monsieur-wifi.com/guest-login
GUEST_WHITELIST_SERVERS=145.32.139.116
GUEST_WHITELIST_DOMAINS=.cnctdwifi.com,.halowifi.com
TWITTER_WHITELIST_DOMAINS=.twitter.com,.x.com,.twimg.com,.google.com,.googleapis.com,.gstatic.com,.google.co.in,.google.fr
FACEBOOK_WHITELIST_DOMAINS=.facebook.com,.fbcdn.net,.graph.facebook.com
TWITTER_WHITELIST_SERVERS='twitter.com,x.com,twimg.com,google.com,googleapis.com,gstatic.com'
FACEBOOK_WHITELIST_SERVERS='facebook.com,fbcdn.net,graph.facebook.com'
GOOGLE_WHITELIST_DOMAINS='.google.com,.googleapis.com,.gstatic.com'
GOOGLE_WHITELIST_SERVERS='google.co.in,google.fr'

# SMS Gateway
BULKSMS_USERNAME=
BULKSMS_PASSWORD=
ENABLE_SMS_SENDING=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

JWT_SECRET=

